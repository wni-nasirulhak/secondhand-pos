# EcomScraper Hub - Environment Configuration

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_PATH=./data/db/ecom_scraper.sqlite

# Browser
HEADLESS=true
BROWSER_TYPE=chromium

# TikTok
TIKTOK_CHROME_PROFILE_PATH=
TIKTOK_STORAGE_STATE_PATH=./data/tiktok_storage_state.json

# Shopee
SHOPEE_STORAGE_STATE_PATH=./data/shopee_storage_state.json

# Lazada
LAZADA_STORAGE_STATE_PATH=./data/lazada_storage_state.json

# Proxy (Optional)
PROXY_ENABLED=false
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./data/logs/app.log

# Webhooks (Legacy)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI Features (Optional)
OPENAI_API_KEY=
AI_MODEL=gpt-4
