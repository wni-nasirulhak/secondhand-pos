{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "secondhand-pos",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": ".vercel/output/static/_worker.js",
  "assets": {
    "directory": ".vercel/output/static"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "secondhan-pos",
      "database_id": "df27b4c5-db62-4b87-ba6b-4ab99ee23788"
    }
  ]
}
