# Shopee Account (for login)
SHOPEE_USERNAME=your_phone_or_email
SHOPEE_PASSWORD=your_password

# OpenClaw/Claude API (for AI replies)
OPENCLAW_API_URL=http://localhost:3000
OPENCLAW_API_KEY=your_gateway_token

# Bot Settings
HEADLESS=false
AUTO_REPLY=true
REPLY_DELAY_MIN=2000
REPLY_DELAY_MAX=5000

# Shopee Live URL
LIVE_URL=https://live.shopee.co.th/pc/xxxxx

# Debug
DEBUG=true
